---
extends: default
rules:
  line-length:
    max: 160
  braces:
    max-spaces-inside: 1   # разрешить читаемое { key: value } в inventory
  comments:
    min-spaces-from-content: 1
  comments-indentation: false
  truthy:
    check-keys: false   # ключ `on:` в GitHub workflow
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
